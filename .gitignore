# =======================================
# Python-Backend / FastAPI/Flask/Django
# =======================================

__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environments (ALL patterns)
venv/
.venv/
*venv/
**/venv/
**/.venv/
**/*venv/
env/
ENV/
*env/
**/*env/


# Environment variables (secrets)
.env
.env.*

# Logs
*.log

# Alembic (keep migrations, ignore cache)
alembic/versions/__pycache__/

instance/
.webassets-cache/

# Django DB (only if using SQLite locally)
db.sqlite3
db.sqlite3-journal

# Django collected static files (generated)
staticfiles/

# Django media uploads (user-generated)
media/

# Django cache
*.cache

# Django migrations cache (NOT migration files)
**/migrations/__pycache__/

# =========================
# Database files (local)
# =========================

*.sqlite3
*.db

